{
  "expo": {
    "name": "SSMSPL Checker",
    "slug": "ssmspl-checker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#4338CA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ssmspl.checker",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs camera access to scan QR codes on ferry tickets."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4338CA"
      },
      "package": "com.ssmspl.checker",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": false,
      "versionCode": 1
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "This app needs camera access to scan QR codes on ferry tickets."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "",
          "project": "",
          "enableSourceMapUpload": false
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://api.carferry.online",
      "sentryDsn": "",
      "eas": {
        "projectId": "cf2ce6ce-7631-453c-9df1-5c36fc25a166"
      }
    },
    "owner": "aryan-dev"
  }
}
