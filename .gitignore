*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Alembic
alembic/versions/*.pyc

# Claude Code local config
.claude/

# Dev scratchpad & scraping artifacts
misc/

# AI prompts / scaffolding
prompts/

# Database dumps & backups — none of these should ever land in git.
# Carve-out for the intentional schema/seed SQL files that DO live in the
# repo: backend/scripts/ddl.sql, backend/scripts/seed_data.sql,
# scripts/phantom_recovery.sql, and any alembic migration .py — those are
# code, not dumps. The patterns below are tight to dump/backup artifacts.
backup.sql
ssmspl_db_dev_back.sql
data/ssmspl_db.sql
*.sql.bak
*.sql.gz
*.dump
*.dump.gz
*.pgdump
*.tar.gz
*.tar.bz2
*.tar.xz
# Any folder named "backups" or "backup" at any depth — covers a stray
# laptop-sync output dir or someone scp-ing dumps into the repo.
backups/
backup/
# Postgres pg_dump custom-format and partial restores
*.pgdump
*.pg_restore

# Tests (local only, not deployed)
backend/tests/

# Throwaway / generated files
tsc_output.txt
ssmspl_project_structure.txt
carferry_in_content.json
test_quick.py
updates_to_deploys_today.md

# Dev utility scripts
scrape_carferry.py
screenshot_portal.py
screenshot_sidebar.py
screenshot_review2.py
screenshot_site.py

# Screenshots & reference images (local only)
screenshots_legacy/
screenshots_responsive/
screenshots_review/
data/ticket_reference.jpeg
data/Report_format/

# Analysis & audit (local only, never commit)
analysis_issues/

# QZ Tray certificate/key files (raw PEM — embedded in code where needed)
*.key
*.crt
!frontend/public/ssmspl-qz.crt

# Vital secrets backup for AI and admin eyes only
SECRETS_VITAL_DO_NOT_COMMIT.md

# Maintenance mode flag files (created at runtime, not committed)
nginx/maintenance/*.flag

# Mobile build artifacts
mobile/build.log
