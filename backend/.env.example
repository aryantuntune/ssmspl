# Application
APP_ENV=development
APP_NAME=SSMSPL
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://ssmspl_user:ssmspl_pass@localhost:5432/ssmspl_db_dev

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend & Backend URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Airpay Payment Gateway (classic redirect kit) — credentials issued by Airpay
AIRPAY_MERCHANT_ID=
AIRPAY_USERNAME=
AIRPAY_PASSWORD=
AIRPAY_SECRET_KEY=
AIRPAY_API_KEY=
AIRPAY_CLIENT_ID=
AIRPAY_BASE_URL=https://payments.airpay.co.in

# QZ Tray signing key (PEM private key — generate with: openssl genrsa 2048)
QZ_PRIVATE_KEY_PEM=

# Payment simulation toggle — set to true to bypass Airpay and use simulator
PAYMENT_SIMULATION=false

# Redis (token blacklist + rate limiting)
# Empty = blacklist disabled (acceptable for local dev without Redis)
REDIS_URL=
RATE_LIMIT_STORAGE_URI=memory://

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ssmspl.com
